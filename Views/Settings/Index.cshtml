@model POS.ViewModels.Settings.StoreSettingsEditViewModel
@{
    ViewData["Title"] = "Settings";
    var success = TempData["SuccessMessage"] as string;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Store settings</h1>
        <div class="text-muted small">Configure store profile, tax, currency, and receipt footer</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success">@success</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="post" class="row g-3" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-12">
                <h2 class="h6 text-muted text-uppercase mb-0">Store information</h2>
            </div>
            <div class="col-12 col-lg-6">
                <label asp-for="StoreName" class="form-label"></label>
                <input asp-for="StoreName" class="form-control" />
                <span asp-validation-for="StoreName" class="text-danger small"></span>
            </div>
            <div class="col-12 col-lg-6">
                <label asp-for="StorePhone" class="form-label"></label>
                <input asp-for="StorePhone" class="form-control" />
                <span asp-validation-for="StorePhone" class="text-danger small"></span>
            </div>
            <div class="col-12 col-lg-6">
                <label asp-for="StoreEmail" class="form-label"></label>
                <input asp-for="StoreEmail" class="form-control" />
                <span asp-validation-for="StoreEmail" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="StoreAddress" class="form-label"></label>
                <textarea asp-for="StoreAddress" class="form-control" rows="2"></textarea>
                <span asp-validation-for="StoreAddress" class="text-danger small"></span>
            </div>

            <div class="col-12 mt-2">
                <h2 class="h6 text-muted text-uppercase mb-0">Tax &amp; currency</h2>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="TaxRatePercent" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="TaxRatePercent" class="form-control text-end" />
                    <span class="input-group-text">%</span>
                </div>
                <span asp-validation-for="TaxRatePercent" class="text-danger small"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="CurrencyCode" class="form-label"></label>
                <input asp-for="CurrencyCode" class="form-control" placeholder="USD" />
                <span asp-validation-for="CurrencyCode" class="text-danger small"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="CurrencySymbol" class="form-label"></label>
                <input asp-for="CurrencySymbol" class="form-control" placeholder="$" />
                <span asp-validation-for="CurrencySymbol" class="text-danger small"></span>
            </div>

            <div class="col-12 mt-2">
                <h2 class="h6 text-muted text-uppercase mb-0">Receipt</h2>
            </div>
            <div class="col-12">
                <label asp-for="ReceiptFooter" class="form-label"></label>
                <textarea asp-for="ReceiptFooter" class="form-control" rows="3" placeholder="Thank you for your purchase."></textarea>
                <span asp-validation-for="ReceiptFooter" class="text-danger small"></span>
                <div class="form-text">Shown on printed receipts and sale detail pages.</div>
            </div>

            <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                <button type="submit" class="btn btn-primary">Save settings</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
