@model POS.ViewModels.SalesHistory.SalesListViewModel
@{
    ViewData["Title"] = "Sales history";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Sales history</h1>
        <div class="text-muted small">Search invoices by receipt, customer, or date</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Sales" asp-action="Index">Open POS</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form class="row g-2 align-items-end mb-3" method="get">
            <div class="col-12 col-lg-4">
                <label class="form-label">Search</label>
                <input name="q" value="@Model.Query" class="form-control" placeholder="Receipt # or customer..." />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label">From</label>
                <input name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" type="date" class="form-control" />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label">To</label>
                <input name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" type="date" class="form-control" />
            </div>
            <div class="col-6 col-lg-1">
                <label class="form-label">Size</label>
                <select name="pageSize" class="form-select">
                    @{
                        var sizes = new[] { 10, 20, 50, 100 };
                        foreach (var s in sizes)
                        {
                            <option value="@s" selected="@(Model.Results.PageSize == s)">@s</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-lg-1 d-grid">
                <button type="submit" class="btn btn-outline-secondary">Go</button>
            </div>
        </form>

        <div class="d-flex justify-content-between mb-2">
            <div class="text-muted small">@Model.Results.TotalCount invoice(s)</div>
            <div class="text-muted small">Page @Model.Results.PageNumber of @Model.Results.TotalPages</div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Receipt #</th>
                        <th>Customer</th>
                        <th class="text-nowrap">Payment</th>
                        <th class="text-end text-nowrap">Total</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Results.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-muted">No sales found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var s in Model.Results.Items)
                        {
                            <tr>
                                <td class="text-muted text-nowrap">@s.SaleDate.LocalDateTime.ToString("g")</td>
                                <td class="fw-semibold text-nowrap">@s.ReceiptNumber</td>
                                <td>@s.Customer</td>
                                <td class="text-muted">@s.PaymentMethod</td>
                                <td class="text-end fw-semibold">@s.Total.ToString("C")</td>
                                <td class="text-end text-nowrap">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@s.Id">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Results.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination pagination-sm mb-0 flex-wrap">
                    <li class="page-item @(Model.Results.HasPrevious ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-q="@Model.Query"
                           asp-route-dateFrom="@(Model.DateFrom?.ToString("o"))"
                           asp-route-dateTo="@(Model.DateTo?.ToString("o"))"
                           asp-route-pageSize="@Model.Results.PageSize"
                           asp-route-pageNumber="@(Model.Results.PageNumber - 1)">Previous</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @Model.Results.PageNumber of @Model.Results.TotalPages</span>
                    </li>
                    <li class="page-item @(Model.Results.HasNext ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-q="@Model.Query"
                           asp-route-dateFrom="@(Model.DateFrom?.ToString("o"))"
                           asp-route-dateTo="@(Model.DateTo?.ToString("o"))"
                           asp-route-pageSize="@Model.Results.PageSize"
                           asp-route-pageNumber="@(Model.Results.PageNumber + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

