@model POS.ViewModels.SalesHistory.SaleDetailsViewModel
@{
    ViewData["Title"] = $"Invoice {Model.ReceiptNumber}";
    string Money(decimal amount) =>
        string.IsNullOrWhiteSpace(Model.CurrencySymbol)
            ? amount.ToString("C")
            : $"{Model.CurrencySymbol}{amount:N2}";
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex flex-wrap justify-content-between gap-3">
        <div>
            <div class="text-muted small">Store</div>
            <div class="fs-5 fw-semibold">@Model.StoreName</div>
            @if (!string.IsNullOrWhiteSpace(Model.StoreAddress))
            {
                <div class="text-muted small mt-1" style="white-space: pre-line;">@Model.StoreAddress</div>
            }
            <div class="text-muted small mt-2">
                @if (!string.IsNullOrWhiteSpace(Model.StorePhone))
                {
                    <span class="me-3">@Model.StorePhone</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.StoreEmail))
                {
                    <span>@Model.StoreEmail</span>
                }
            </div>
        </div>
        <div class="text-end">
            <div class="text-muted small">Currency</div>
            <div class="fw-semibold">@Model.CurrencyCode</div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Invoice <span class="text-muted">@Model.ReceiptNumber</span></h1>
        <div class="text-muted small">@Model.SaleDate.LocalDateTime.ToString("f")</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back to history</a>
        <button type="button" class="btn btn-primary btn-sm" onclick="window.print()">Print</button>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-xl-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Customer</div>
                <div class="fw-semibold">@Model.Customer</div>

                <hr />

                <div class="d-flex justify-content-between">
                    <div class="text-muted">Payment method</div>
                    <div class="fw-semibold">@Model.PaymentMethod</div>
                </div>

                <div class="d-flex justify-content-between mt-2">
                    <div class="text-muted">Paid</div>
                    <div class="fw-semibold">@Money(Model.PaidAmount)</div>
                </div>

                <div class="d-flex justify-content-between mt-2">
                    <div class="text-muted">Change</div>
                    <div class="fw-semibold">@Money(Model.ChangeAmount)</div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div class="text-muted">Subtotal</div>
                    <div class="fw-semibold">@Money(Model.Subtotal)</div>
                </div>
                <div class="d-flex justify-content-between mt-2">
                    <div class="text-muted">Discount</div>
                    <div class="fw-semibold">@Money(Model.DiscountAmount)</div>
                </div>
                <div class="d-flex justify-content-between mt-2">
                    <div class="text-muted">Tax</div>
                    <div class="fw-semibold">@Money(Model.TaxAmount)</div>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <div class="fw-semibold">Total</div>
                    <div class="fs-4 fw-semibold">@Money(Model.Total)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <div class="fw-semibold">Items</div>
                <div class="text-muted small">Invoice line items</div>
            </div>
            <div class="card-body pt-3">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-nowrap">Barcode</th>
                                <th class="text-end text-nowrap">Qty</th>
                                <th class="text-end text-nowrap">Unit price</th>
                                <th class="text-end text-nowrap">Line total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var i in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">@i.ProductName</td>
                                    <td class="text-muted">@i.Barcode</td>
                                    <td class="text-end">@i.Quantity</td>
                                    <td class="text-end">@Money(i.UnitPrice)</td>
                                    <td class="text-end fw-semibold">@Money(i.LineTotal)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ReceiptFooter))
{
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body text-center text-muted small" style="white-space: pre-line;">
            @Model.ReceiptFooter
        </div>
    </div>
}

