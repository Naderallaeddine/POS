@model POS.ViewModels.Categories.CategoryListViewModel
@{
    ViewData["Title"] = "Categories";
    var error = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Categories</h1>
        <div class="text-muted small">Organize your product catalog</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Products" asp-action="Index">Back to products</a>
        <a class="btn btn-primary btn-sm" asp-action="Create">Add category</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-warning">@error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-end text-nowrap">Products</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Categories.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted">No categories yet.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Categories)
                        {
                            <tr>
                                <td class="fw-semibold">@c.Name</td>
                                <td class="text-muted">@c.Description</td>
                                <td class="text-end">@c.ProductsCount</td>
                                <td class="text-end text-nowrap">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this category?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

