@model POS.ViewModels.Customers.CustomerListViewModel
@{
    ViewData["Title"] = "Customers";
    var error = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Customers</h1>
        <div class="text-muted small">Search, manage, and maintain customer records</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary btn-sm" asp-action="Create">Add customer</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-warning">@error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form class="row g-2 align-items-end mb-3" method="get">
            <div class="col-12 col-md-6 col-lg-5">
                <label class="form-label">Search</label>
                <input name="q" value="@Model.Query" class="form-control" placeholder="Name, email, or phone..." />
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label class="form-label">Page size</label>
                <select name="pageSize" class="form-select">
                    @{
                        var sizes = new[] { 10, 20, 50, 100 };
                        foreach (var s in sizes)
                        {
                            <option value="@s" selected="@(Model.Results.PageSize == s)">@s</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-2 d-grid">
                <button type="submit" class="btn btn-outline-secondary">Search</button>
            </div>
            <div class="col-12 col-lg-3 text-lg-end">
                <div class="text-muted small">
                    @Model.Results.TotalCount result(s)
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Customer</th>
                        <th>Email</th>
                        <th class="text-nowrap">Phone</th>
                        <th class="text-end text-nowrap">Sales</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Results.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-muted">No customers found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Results.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@c.FullName</td>
                                <td class="text-muted">@c.Email</td>
                                <td class="text-muted">@c.Phone</td>
                                <td class="text-end">@c.SalesCount</td>
                                <td class="text-end text-nowrap">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this customer?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Results.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination pagination-sm mb-0 flex-wrap">
                    <li class="page-item @(Model.Results.HasPrevious ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-q="@Model.Query"
                           asp-route-pageSize="@Model.Results.PageSize"
                           asp-route-pageNumber="@(Model.Results.PageNumber - 1)">Previous</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @Model.Results.PageNumber of @Model.Results.TotalPages</span>
                    </li>
                    <li class="page-item @(Model.Results.HasNext ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-q="@Model.Query"
                           asp-route-pageSize="@Model.Results.PageSize"
                           asp-route-pageNumber="@(Model.Results.PageNumber + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@{
    ViewData["Title"] = "Customers";
}

<h1 class="h3 mb-3">Customers</h1>
<p class="text-muted">Customer profiles and loyalty data belong in this module.</p>
