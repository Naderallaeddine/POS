@using Microsoft.AspNetCore.Identity
@inject SignInManager<POS.Data.Entities.ApplicationUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small">@User.Identity?.Name</span>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary btn-sm">Sign out</button>
        </form>
    </div>
}
else
{
    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Sign in</a>
}
