@model POS.ViewModels.Products.ProductEditViewModel
@{
    ViewData["Title"] = "Add product";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">Add product</h1>
        <div class="text-muted small">Create a new item in your catalog</div>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post" class="row g-3" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-12 col-lg-7">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-5">
                <label asp-for="Barcode" class="form-label"></label>
                <input asp-for="Barcode" class="form-control" />
                <span asp-validation-for="Barcode" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-6">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">Select category...</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                <div class="form-text">
                    Need a new category? <a asp-controller="Categories" asp-action="Create">Add one</a>.
                </div>
            </div>

            <div class="col-12 col-lg-6 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="CostPrice" class="form-label"></label>
                <input asp-for="CostPrice" class="form-control" />
                <span asp-validation-for="CostPrice" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="SalePrice" class="form-label"></label>
                <input asp-for="SalePrice" class="form-control" />
                <span asp-validation-for="SalePrice" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="StockQuantity" class="form-label"></label>
                <input asp-for="StockQuantity" class="form-control" />
                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-2 justify-content-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

