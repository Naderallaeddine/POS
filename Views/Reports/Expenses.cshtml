@model POS.ViewModels.Reports.ExpenseReportViewModel
@{
    ViewData["Title"] = "Expense report";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Expense report</h1>
        <div class="text-muted small">Operational expenses for management review</div>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-6 col-lg-3">
                <label class="form-label">From</label>
                <input type="date" name="dateFrom" value="@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label">To</label>
                <input type="date" name="dateTo" value="@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))" class="form-control" />
            </div>
            <div class="col-12 col-lg-2 d-grid">
                <button class="btn btn-outline-secondary" type="submit">Apply</button>
            </div>
            <div class="col-12 col-lg-4 text-lg-end">
                <div class="text-muted small">Count: <strong>@Model.ExpensesCount</strong></div>
                <div class="text-muted small">Total: <strong>@Model.TotalExpenses.ToString("C")</strong></div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-nowrap">Date</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th class="text-end text-nowrap">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="4" class="text-muted">No expenses for the selected range.</td></tr>
                    }
                    else
                    {
                        foreach (var r in Model.Rows)
                        {
                            <tr>
                                <td class="text-muted text-nowrap">@r.Date.LocalDateTime.ToString("g")</td>
                                <td class="fw-semibold">@r.Title</td>
                                <td class="text-muted">@r.Category</td>
                                <td class="text-end fw-semibold">@r.Amount.ToString("C")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

