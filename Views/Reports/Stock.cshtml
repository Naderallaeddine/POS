@model POS.ViewModels.Reports.StockReportViewModel
@{
    ViewData["Title"] = "Stock report";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Stock report</h1>
        <div class="text-muted small">Inventory snapshot for management review</div>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Products</div>
                <div class="fs-4 fw-semibold">@Model.ProductsCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Low stock</div>
                <div class="fs-4 fw-semibold">@Model.LowStockCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-nowrap">Barcode</th>
                        <th>Category</th>
                        <th class="text-end text-nowrap">Stock</th>
                        <th class="text-end text-nowrap">Reorder</th>
                        <th class="text-nowrap">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="6" class="text-muted">No products found.</td></tr>
                    }
                    else
                    {
                        foreach (var r in Model.Rows)
                        {
                            <tr class="@(r.IsLowStock ? "table-warning" : "")">
                                <td class="fw-semibold">@r.ProductName</td>
                                <td class="text-muted">@r.Barcode</td>
                                <td>@r.CategoryName</td>
                                <td class="text-end">@r.StockQuantity</td>
                                <td class="text-end">@((r.ReorderLevel == 0 ? 10 : r.ReorderLevel))</td>
                                <td>
                                    @if (!r.IsActive)
                                    {
                                        <span class="badge text-bg-secondary">Inactive</span>
                                    }
                                    else if (r.IsLowStock)
                                    {
                                        <span class="badge text-bg-warning">Low stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">OK</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

